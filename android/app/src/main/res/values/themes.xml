<resources>
    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Background color of the splash screen -->
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <!-- The icon to display -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <!-- The theme to inherit after the splash screen is dismissed -->
        <item name="postSplashScreenTheme">@style/Theme.SudokuSolver</item>
    </style>

    <style name="Theme.SudokuSolver" parent="android:Theme.Material.Light.NoActionBar" />
</resources>
